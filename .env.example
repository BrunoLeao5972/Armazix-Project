# ─── Neon (PostgreSQL) ──────────────────────────────────────────
# Pegue em: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://neondb_owner:senha@ep-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Cloudflare ─────────────────────────────────────────────────
# Pegue em: https://dash.cloudflare.com → Workers & Pages
CLOUDFLARE_ACCOUNT_ID=sua_account_id
CLOUDFLARE_API_TOKEN=seu_api_token

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:8081

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=uma_chave_secreta_muito_longa_e_aleatoria
SESSION_DURATION_DAYS=7

# ─── Encryption (AES-256-GCM) ──────────────────────────────────
# Gere uma chave de 32 caracteres: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=sua_chave_de_32_caracteres_para_aes

# ─── Email (Resend) ────────────────────────────────────────────
# Pegue em: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Webhook Security ──────────────────────────────────────────
# Secret key to validate incoming webhooks (optional but recommended)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY=webhook_secret_key_aqui

# ─── Upstash Redis (Cache + Rate Limiting) ──────────────────────
# Sem estas vars o sistema funciona normalmente, mas sem cache Redis.
# Todas as queries vão direto ao banco — adequado para desenvolvimento local.
#
# Como provisionar (gratuito, sem cartão):
#   1. Acesse https://upstash.com → Create Database
#   2. Region: us-east-1 (mais próximo do Neon us-east-2 e do CF)
#   3. Copie REST URL e REST Token do painel → REST API
#   4. Em produção: wrangler secret put UPSTASH_REDIS_REST_URL
#                   wrangler secret put UPSTASH_REDIS_REST_TOKEN
#
# Funcionalidades habilitadas com Redis configurado:
#   ✓ Cache de produtos e categorias públicos (TTL: 1h, invalidação imediata)
#   ✓ Cache de configuração de loja — logo, cores, pagamento (TTL: 10min)
#   ✓ Rate limiting distribuído entre todos os PoPs do Cloudflare
#   ✓ Armazenamento de OTP para autenticação via WhatsApp
UPSTASH_REDIS_REST_URL=https://seu-banco.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_token_upstash_aqui
